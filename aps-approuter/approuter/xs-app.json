{
  "authenticationMethod": "route", 
  "sessionTimeout": 30,
  "welcomeFile": "/index.html", 
  "logout": {
      "logoutEndpoint": "/logout",
      "logoutPage": "/aps/apps/home/index-goodbye.html"
  },
  "routes": [
    {
      "source": "^/sap/opu/odata/(.*)$",
      "target": "/sap/opu/odata/$1",
      "destination": "Gateway-x96-SSO",
      "authenticationType": "xsuaa"
    },
    {                                                    
      "source": "^/role-coll-scanner-api/(.*)$",
      "target": "/api/$1",
      "destination": "role-coll-scanner-web-api",
      "authenticationType": "xsuaa"
    },
    {
     "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}