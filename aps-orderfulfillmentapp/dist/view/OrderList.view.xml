<mvc:View
    controllerName="orderfulfillment.controller.OrderList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    displayBlock="true">

    <Page
        id="orderListPage"
        title="{i18n>orderListTitle}"
        showNavButton="false">

        <headerContent>
            <Button
                text="{i18n>btnCreateOrder}"
                type="Emphasized"
                icon="sap-icon://add"
                press=".onCreateOrder"/>
            <Button
                icon="sap-icon://refresh"
                tooltip="{i18n>btnRefresh}"
                press=".onRefresh"/>
        </headerContent>

        <subHeader>
            <Bar>
                <contentLeft>
                    <SearchField
                        id="searchField"
                        placeholder="{i18n>searchPlaceholder}"
                        width="30rem"
                        search=".onSearch"
                        liveChange=".onSearch"/>
                </contentLeft>
                <contentRight>
                    <SegmentedButton
                        id="statusFilter"
                        selectionChange=".onStatusFilterChange">
                        <items>
                            <SegmentedButtonItem key=""   text="{i18n>filterAll}"/>
                            <SegmentedButtonItem key="NW" text="{i18n>filterNew}"/>
                            <SegmentedButtonItem key="PR" text="{i18n>filterProcessing}"/>
                            <SegmentedButtonItem key="SH" text="{i18n>filterShipped}"/>
                            <SegmentedButtonItem key="DL" text="{i18n>filterDelivered}"/>
                            <SegmentedButtonItem key="CA" text="{i18n>filterCancelled}"/>
                        </items>
                    </SegmentedButton>
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <Table
                id="ordersTable"
                items="{
                    path: '/Orders',
                    sorter: { path: 'OrderDate', descending: true }
                }"
                noDataText="{i18n>orderListNoData}"
                mode="SingleSelectMaster"
                selectionChange=".onOrderSelect">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title id="tableTitle" text="Orders"/>
                        <ToolbarSpacer/>
                        <Button
                            icon="sap-icon://sort"
                            text="Sort"
                            press=".onSort"/>
                        <Button
                            icon="sap-icon://filter"
                            text="Filter"
                            press=".onFilter"/>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="10rem">
                        <Text text="{i18n>fieldOrderId}"/>
                    </Column>
                    <Column>
                        <Text text="{i18n>fieldCustomer}"/>
                    </Column>
                    <Column width="10rem" hAlign="Center">
                        <Text text="{i18n>fieldOrderDate}"/>
                    </Column>
                    <Column width="10rem" hAlign="Center">
                        <Text text="{i18n>fieldDeliveryDate}"/>
                    </Column>
                    <Column width="9rem" hAlign="Center">
                        <Text text="{i18n>fieldStatus}"/>
                    </Column>
                    <Column width="10rem" hAlign="End">
                        <Text text="{i18n>fieldTotalAmount}"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="Navigation"
                        press=".onOrderPress">
                        <cells>
                            <ObjectIdentifier
                                title="{OrderId}"
                                titleActive="false"/>
                            <Text text="{CustomerName}"/>
                            <Text text="{
                                path: 'OrderDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { style: 'medium' }
                            }"/>
                            <Text text="{
                                path: 'DeliveryDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { style: 'medium' }
                            }"/>
                            <ObjectStatus
                                text="{
                                    path: 'Status',
                                    formatter: '.formatter.statusText'
                                }"
                                state="{
                                    path: 'Status',
                                    formatter: '.formatter.statusState'
                                }"/>
                            <ObjectNumber
                                number="{
                                    path: 'TotalAmount',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
                                }"
                                unit="{Currency}"
                                state="None"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
