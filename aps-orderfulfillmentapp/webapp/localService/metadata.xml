<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0" xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx"
           xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata"
           xmlns:sap="http://www.sap.com/Protocols/SAPData">
  <edmx:DataServices m:DataServiceVersion="2.0">
    <Schema Namespace="ZORDER_FULFILLMENT_SRV" xml:lang="en"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

      <!-- Order Entity -->
      <EntityType Name="OrderType" sap:content-version="1">
        <Key><PropertyRef Name="OrderId"/></Key>
        <Property Name="OrderId"        Type="Edm.String" Nullable="false" MaxLength="10" sap:label="Order ID" sap:creatable="false" sap:updatable="false"/>
        <Property Name="CustomerId"     Type="Edm.String" MaxLength="10"  sap:label="Customer ID"/>
        <Property Name="CustomerName"   Type="Edm.String" MaxLength="80"  sap:label="Customer Name"/>
        <Property Name="OrderDate"      Type="Edm.DateTime"               sap:label="Order Date" sap:display-format="Date"/>
        <Property Name="DeliveryDate"   Type="Edm.DateTime"               sap:label="Delivery Date" sap:display-format="Date"/>
        <Property Name="Status"         Type="Edm.String" MaxLength="2"   sap:label="Status"/>
        <Property Name="TotalAmount"    Type="Edm.Decimal" Precision="15" Scale="2" sap:label="Total Amount" sap:unit="Currency"/>
        <Property Name="Currency"       Type="Edm.String" MaxLength="5"   sap:label="Currency" sap:semantics="currency-code"/>
        <Property Name="ShippingAddress" Type="Edm.String" MaxLength="255" sap:label="Shipping Address"/>
        <Property Name="Notes"          Type="Edm.String" MaxLength="500" sap:label="Notes"/>
        <NavigationProperty Name="Items" Relationship="ZORDER_FULFILLMENT_SRV.OrderToItems"
                            FromRole="OrderPrincipal" ToRole="ItemDependent"/>
      </EntityType>

      <!-- OrderItem Entity -->
      <EntityType Name="OrderItemType" sap:content-version="1">
        <Key>
          <PropertyRef Name="OrderId"/>
          <PropertyRef Name="ItemId"/>
        </Key>
        <Property Name="OrderId"     Type="Edm.String" Nullable="false" MaxLength="10" sap:label="Order ID"/>
        <Property Name="ItemId"      Type="Edm.String" Nullable="false" MaxLength="6"  sap:label="Item No"/>
        <Property Name="ProductId"   Type="Edm.String" MaxLength="18"  sap:label="Product ID"/>
        <Property Name="ProductName" Type="Edm.String" MaxLength="100" sap:label="Product Name"/>
        <Property Name="Quantity"    Type="Edm.Decimal" Precision="13" Scale="3" sap:label="Quantity"/>
        <Property Name="Unit"        Type="Edm.String" MaxLength="3"   sap:label="Unit"/>
        <Property Name="UnitPrice"   Type="Edm.Decimal" Precision="15" Scale="2" sap:label="Unit Price"/>
        <Property Name="TotalPrice"  Type="Edm.Decimal" Precision="15" Scale="2" sap:label="Total Price"/>
        <Property Name="Currency"    Type="Edm.String" MaxLength="5"   sap:label="Currency" sap:semantics="currency-code"/>
        <Property Name="FulfilledQty" Type="Edm.Decimal" Precision="13" Scale="3" sap:label="Fulfilled Qty"/>
      </EntityType>

      <!-- Customer Entity -->
      <EntityType Name="CustomerType" sap:content-version="1">
        <Key><PropertyRef Name="CustomerId"/></Key>
        <Property Name="CustomerId"    Type="Edm.String" Nullable="false" MaxLength="10" sap:label="Customer ID"/>
        <Property Name="CustomerName"  Type="Edm.String" MaxLength="80"  sap:label="Customer Name"/>
        <Property Name="Email"         Type="Edm.String" MaxLength="100" sap:label="Email"/>
        <Property Name="Phone"         Type="Edm.String" MaxLength="30"  sap:label="Phone"/>
        <Property Name="Address"       Type="Edm.String" MaxLength="255" sap:label="Address"/>
      </EntityType>

      <!-- Associations -->
      <Association Name="OrderToItems">
        <End Type="ZORDER_FULFILLMENT_SRV.OrderType"     Multiplicity="1"  Role="OrderPrincipal"/>
        <End Type="ZORDER_FULFILLMENT_SRV.OrderItemType" Multiplicity="*"  Role="ItemDependent"/>
        <ReferentialConstraint>
          <Principal Role="OrderPrincipal"><PropertyRef Name="OrderId"/></Principal>
          <Dependent Role="ItemDependent"><PropertyRef Name="OrderId"/></Dependent>
        </ReferentialConstraint>
      </Association>

      <!-- Entity Container -->
      <EntityContainer Name="ZORDER_FULFILLMENT_SRV_Entities" m:IsDefaultEntityContainer="true">
        <EntitySet Name="Orders"      EntityType="ZORDER_FULFILLMENT_SRV.OrderType"
                   sap:deletable="false" sap:searchable="true" sap:content-version="1"/>
        <EntitySet Name="OrderItems"  EntityType="ZORDER_FULFILLMENT_SRV.OrderItemType"
                   sap:deletable="false" sap:content-version="1"/>
        <EntitySet Name="Customers"   EntityType="ZORDER_FULFILLMENT_SRV.CustomerType"
                   sap:deletable="false" sap:content-version="1"/>

        <AssociationSet Name="OrderToItems_Set" Association="ZORDER_FULFILLMENT_SRV.OrderToItems">
          <End EntitySet="Orders"     Role="OrderPrincipal"/>
          <End EntitySet="OrderItems" Role="ItemDependent"/>
        </AssociationSet>

        <!-- Function Imports for fulfillment actions -->
        <FunctionImport Name="ConfirmOrder" ReturnType="ZORDER_FULFILLMENT_SRV.OrderType"
                        m:HttpMethod="POST" sap:action-for="ZORDER_FULFILLMENT_SRV.OrderType">
          <Parameter Name="OrderId" Type="Edm.String" Mode="In"/>
        </FunctionImport>
        <FunctionImport Name="ShipOrder" ReturnType="ZORDER_FULFILLMENT_SRV.OrderType"
                        m:HttpMethod="POST" sap:action-for="ZORDER_FULFILLMENT_SRV.OrderType">
          <Parameter Name="OrderId"       Type="Edm.String"   Mode="In"/>
          <Parameter Name="TrackingNumber" Type="Edm.String"   Mode="In"/>
          <Parameter Name="ShipDate"      Type="Edm.DateTime" Mode="In"/>
        </FunctionImport>
        <FunctionImport Name="CancelOrder" ReturnType="ZORDER_FULFILLMENT_SRV.OrderType"
                        m:HttpMethod="POST" sap:action-for="ZORDER_FULFILLMENT_SRV.OrderType">
          <Parameter Name="OrderId" Type="Edm.String" Mode="In"/>
          <Parameter Name="Reason"  Type="Edm.String" Mode="In"/>
        </FunctionImport>
      </EntityContainer>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
